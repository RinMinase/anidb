{
  "name": "rin-anidb",
  "description": "Rin Minase's AniDB using Preact with Vite and deployed to Netlify",
  "homepage": "https://anidb.netlify.com/",
  "version": "0.3.0",
  "license": "MIT",
  "author": "Rin Minase",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/RinMinase/anidb"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run lint-summary & tsgo && vite build",
    "lint": "biome check",
    "lint-summary": "biome check --reporter=summary",
    "lint-write": "biome check --write",
    "biome": "biome",
    "cz": "cz"
  },
  "dependencies": {
    "@dagrejs/dagre": "3.0.0",
    "@hello-pangea/dnd": "18.0.1",
    "@hookform/resolvers": "5.2.2",
    "@mui/material": "7.3.10",
    "@mui/x-date-pickers": "8.27.2",
    "@xyflow/react": "12.10.2",
    "axios": "1.15.0",
    "chart.js": "4.5.1",
    "chartjs-plugin-datalabels": "2.2.0",
    "date-fns": "4.1.0",
    "es-cookie": "1.5.0",
    "es-toolkit": "1.45.1",
    "preact": "10.29.1",
    "preact-iso": "2.11.1",
    "react-dropzone": "15.0.0",
    "react-feather": "2.0.10",
    "react-hook-form": "7.72.1",
    "react-markdown": "10.1.0",
    "react-scroll": "1.9.3",
    "react-waypoint": "10.3.0",
    "react-window": "2.2.7",
    "remark-gfm": "4.0.1",
    "sonner": "2.0.7",
    "ua-parser-js": "2.0.9",
    "yup": "1.7.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@date-io/date-fns": "3.2.1",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@preact/preset-vite": "2.10.5",
    "@types/react-scroll": "1.8.10",
    "@typescript/native-preview": "7.0.0-dev.20260410.1",
    "commitizen": "4.3.1",
    "cz-emoji-conventional": "1.2.1",
    "devmoji": "2.3.0",
    "preact-render-to-string": "6.6.7",
    "vite": "8.0.3",
    "vite-plugin-svgr": "5.2.0",
    "yorkie": "2.0.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "yarn": "^1.22.22"
  },
  "gitHooks": {
    "prepare-commit-msg": "devmoji -e"
  },
  "config": {
    "commitizen": {
      "path": "cz-emoji-conventional"
    }
  }
}
